# ─── Stock Analyzer Configuration Template ───
# Rename this file to .env and fill in your details.
# DO NOT commit the .env file containing real keys to Git!

# 🤖 OpenRouter AI Configuration
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 💬 Telegram Bot Configuration
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID via @userinfobot or similar
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 🗂️ Portfolio Sources (Comma-separated list of active sources)
# Options: local, sheets, angelone, groww
PORTFOLIO_SOURCES=local

# 🛢️ PostgreSQL Database Connection (Required for persistent production hosting)
# Format: postgres://username:password@host:port/database
# Leave blank to fallback to local JSON file (data/portfolio.json)
DATABASE_URL=

# 📊 Google Sheets (Optional: only needed if 'sheets' is listed in PORTFOLIO_SOURCES)
GOOGLE_SHEETS_ID=
